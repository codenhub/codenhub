---
import type { PackageStatus } from "../lib/catalog-core";

interface Props {
  status: PackageStatus;
}

const { status } = Astro.props;
const statusIntent = status === "experimental" ? "warning" : "destructive";
---

{
  status !== "active" && (
    <span class:list={["badge", "soft", "capitalize", statusIntent]}>{status}</span>
  )
}
