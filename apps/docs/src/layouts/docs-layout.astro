---
import PackageNavigation from "../components/package-navigation.astro";
import type { PublicDocument, PublicPackage } from "../lib/catalog";
import BaseLayout from "./base-layout.astro";

interface Props {
  currentPackage: PublicPackage;
  document: PublicDocument;
}

const { currentPackage, document } = Astro.props;
const tocHeadings = document.headings.filter(({ depth }) => depth === 2 || depth === 3);
---

<BaseLayout
  description={document.description ?? currentPackage.description}
  sectionTitle={currentPackage.label}
  title={document.title}
>
  <details class="mobile-navigation">
    <summary>Browse documentation</summary>
    <div class="mobile-navigation-panel">
      <PackageNavigation currentPackage={currentPackage} currentRoute={document.route} />
    </div>
  </details>

  <div class="docs-shell section-content wide">
    <aside class="left-rail">
      <PackageNavigation currentPackage={currentPackage} currentRoute={document.route} />
    </aside>

    <main class="document-column" id="main-content">
      <article class="markdown-content">
        <slot />
      </article>
    </main>

    <aside class="toc-rail">
      {
        tocHeadings.length > 0 && (
          <nav aria-label="On this page">
            <p class="rail-title">On this page</p>
            <ol>
              {tocHeadings.map((heading) => (
                <li class:list={{ nested: heading.depth === 3 }}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }
    </aside>
  </div>
</BaseLayout>
