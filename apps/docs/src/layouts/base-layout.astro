---
import { siteConfig } from "../site-config";
import "../styles/global.css";

interface Props {
  description?: string;
  sectionTitle?: string;
  title?: string;
}

const { description = siteConfig.description, sectionTitle, title } = Astro.props;
const pageTitle =
  title === undefined
    ? siteConfig.title
    : sectionTitle === undefined
      ? `${title} | ${siteConfig.title}`
      : `${title} | ${sectionTitle} | ${siteConfig.title}`;
const isHome = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width" name="viewport" />
    <meta content={description} name="description" />
    <link href="/favicon.ico" rel="icon" sizes="any" />
    <script is:inline>
      (() => {
        const storageKey = "codenhub-docs-theme";

        try {
          const storedTheme = localStorage.getItem(storageKey);
          const theme =
            storedTheme === "light" || storedTheme === "dark"
              ? storedTheme
              : matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";

          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
      })();
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-header">
      <div class="site-header-content section-content wide">
        <a aria-label={`${siteConfig.title} home`} class="brand" href="/">
          <img
            alt=""
            aria-hidden="true"
            class="brand-logo brand-logo-on-light"
            height="255"
            src="/logo-dark.svg"
            width="984"
          />
          <img
            alt=""
            aria-hidden="true"
            class="brand-logo brand-logo-on-dark"
            height="255"
            src="/logo-light.svg"
            width="984"
          />
        </a>
        <div class="header-end">
          <nav aria-label="Primary" class="primary-navigation">
            <a aria-current={isHome ? "page" : undefined} href="/">Home</a>
            <a aria-current={!isHome ? "page" : undefined} href="/packages/">Packages</a>
          </nav>
          <nav aria-label="Site actions" class="header-actions">
            <a aria-label="CodenHub on GitHub" class="header-icon-link" href={siteConfig.githubUrl}>
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path
                  d="M8 0C3.58 0 0 3.64 0 8.13c0 3.59 2.29 6.64 5.47 7.71.4.08.55-.17.55-.39 0-.19-.01-.83-.01-1.51-2.01.38-2.53-.5-2.69-.96-.09-.23-.48-.96-.82-1.15-.28-.15-.68-.53-.01-.54.63-.01 1.08.59 1.23.83.72 1.23 1.87.88 2.33.67.07-.53.28-.88.51-1.08-1.78-.21-3.64-.91-3.64-4.02 0-.89.31-1.62.82-2.19-.08-.2-.36-1.04.08-2.16 0 0 .67-.22 2.2.84A7.48 7.48 0 0 1 8 3.91c.68 0 1.36.09 2 .27 1.53-1.06 2.2-.84 2.2-.84.44 1.12.16 1.96.08 2.16.51.57.82 1.29.82 2.19 0 3.12-1.87 3.81-3.65 4.02.29.25.54.74.54 1.51 0 1.09-.01 1.97-.01 2.24 0 .22.15.47.55.39A8.12 8.12 0 0 0 16 8.13C16 3.64 12.42 0 8 0Z"
                />
              </svg>
            </a>
            <button aria-label="Switch theme" class="theme-toggle" data-theme-toggle type="button">
              <svg aria-hidden="true" class="theme-icon theme-icon-moon" viewBox="0 0 24 24">
                <path d="M20.4 15.2A9 9 0 0 1 8.8 3.6 9 9 0 1 0 20.4 15.2Z" />
              </svg>
              <svg aria-hidden="true" class="theme-icon theme-icon-sun" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="4" />
                <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
              </svg>
            </button>
          </nav>
        </div>
      </div>
    </header>
    <slot />
    <script>
      import { createCodeCopyController, findCodeCopyStatus } from "../lib/markdown/code-copy";

      const storageKey = "codenhub-docs-theme";
      const themeToggle = document.querySelector("[data-theme-toggle]");

      const updateThemeToggle = () => {
        if (!(themeToggle instanceof HTMLButtonElement)) {
          return;
        }

        const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        const nextTheme = currentTheme === "dark" ? "light" : "dark";
        themeToggle.setAttribute("aria-label", `Switch to ${nextTheme} theme`);
        themeToggle.title = `Switch to ${nextTheme} theme`;
      };

      updateThemeToggle();

      themeToggle?.addEventListener("click", () => {
        const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = nextTheme;

        try {
          localStorage.setItem(storageKey, nextTheme);
        } catch {
          // Theme still applies for this page when storage is unavailable.
        }

        updateThemeToggle();
      });

      const copyController = createCodeCopyController();

      if (document.documentElement.dataset.codeCopyReady !== "true") {
        document.documentElement.dataset.codeCopyReady = "true";
        document.addEventListener("click", async (event) => {
          const target = event.target;
          const copyButton =
            target instanceof Element ? target.closest<HTMLButtonElement>("[data-code-copy]") : null;
          if (copyButton === null) {
            return;
          }

          const code = copyButton.closest(".code-block")?.querySelector("code")?.textContent;
          if (code === undefined) {
            return;
          }

          const status = findCodeCopyStatus(copyButton);
          if (status === null) {
            return;
          }

          await copyController.copy({ button: copyButton, clipboard: navigator.clipboard, code, status });
        });
      }
    </script>
  </body>
</html>
