{
  "name": "@codenhub/tauri-plugin-webview",
  "version": "0.0.1",
  "private": false,
  "description": "TypeScript plugin for spawning and controlling Tauri v2 WebViews.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenhub/codenhub.git",
    "directory": "packages/plugins/tauri/webview"
  },
  "files": [
    "dist",
    "docs/*.md",
    "llms.txt",
    "llms-full.txt",
    "rust/webview_commands.rs"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean --no-fixed-extension",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "status:npm": "npm view @codenhub/tauri-plugin-webview version dist-tags time --json && npm dist-tag ls @codenhub/tauri-plugin-webview && npm access get status @codenhub/tauri-plugin-webview",
    "status:pack": "npm pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tauri-apps/api": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "codenhub": {
    "docs": {
      "status": "experimental"
    }
  }
}
