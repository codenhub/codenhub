{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bubble Plugin Configuration Schema",
  "description": "Schema for validating and autocompleting bubble.json plugin definitions.",
  "type": "object",
  "required": ["name"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to the JSON schema file"
    },
    "name": {
      "type": "string",
      "description": "The name of the Bubble plugin"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the plugin's functionality"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the plugin"
    },
    "actions": {
      "type": "array",
      "description": "List of client-side and server-side actions",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the action (matches filename in src/actions/<name>.ts)"
          },
          "type": {
            "type": "string",
            "enum": ["client", "server"],
            "description": "Action type: 'client' for browser-side, 'server' for node-side"
          },
          "properties": {
            "type": "object",
            "description": "Parameters configured in the Bubble dashboard for this action",
            "additionalProperties": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["text", "number", "boolean", "date", "object", "any"],
                  "description": "The parameter type"
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether the parameter is required"
                },
                "default": {
                  "description": "The default value for the parameter"
                },
                "doc": {
                  "type": "string",
                  "description": "Documentation/helper text for the parameter"
                }
              }
            }
          }
        }
      }
    },
    "elements": {
      "type": "array",
      "description": "List of custom visual elements",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the element (matches directory in src/elements/<name>/)"
          },
          "properties": {
            "type": "object",
            "description": "Visual element configuration parameters",
            "additionalProperties": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["text", "number", "boolean", "date", "object", "any"],
                  "description": "The property type"
                },
                "required": {
                  "type": "boolean",
                  "description": "Whether the property is required"
                },
                "default": {
                  "description": "The default value for the property"
                },
                "doc": {
                  "type": "string",
                  "description": "Documentation/helper text for the property"
                }
              }
            }
          },
          "events": {
            "type": "array",
            "description": "Custom events triggered by the visual element (e.g. via instance.triggerEvent)",
            "items": {
              "type": "string"
            }
          },
          "states": {
            "type": "array",
            "description": "Custom states exposed by the visual element (e.g. published via instance.publishState)",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "The custom state name"
                },
                "type": {
                  "type": "string",
                  "enum": ["text", "number", "boolean", "date", "object", "any"],
                  "description": "The value type of the custom state"
                }
              }
            }
          }
        }
      }
    }
  }
}
