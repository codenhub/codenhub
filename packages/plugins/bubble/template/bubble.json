{
  "$schema": "node_modules/bubble-plugin/bubble.schema.json",
  "name": "Bubble Plugin Template",
  "actions": [
    {
      "name": "action",
      "type": "client",
      "properties": {
        "my_param": {
          "type": "text",
          "required": true
        }
      }
    }
  ],
  "elements": [
    {
      "name": "my-element",
      "properties": {
        "bg_color": {
          "type": "text",
          "default": "#ffffff"
        }
      }
    }
  ]
}
