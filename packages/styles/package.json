{
  "name": "@codenhub/styles",
  "version": "0.0.4",
  "private": false,
  "description": "CSS-only Codenhub design tokens, base styles, and composable UI helper classes.",
  "homepage": "https://github.com/codenhub/codenhub/tree/main/packages/styles",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenhub/codenhub.git",
    "directory": "packages/styles"
  },
  "files": [
    "dist",
    "NOTICE",
    "README.md",
    "docs/index.md",
    "docs/tokens.md",
    "docs/classes.md",
    "docs/accessibility.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "type": "module",
  "exports": {
    ".": {
      "style": "./dist/index.css",
      "import": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./theme": {
      "style": "./dist/theme.css",
      "import": "./dist/theme.css",
      "default": "./dist/theme.css"
    },
    "./components": {
      "style": "./dist/components.css",
      "import": "./dist/components.css",
      "default": "./dist/components.css"
    },
    "./tw": "./dist/tw/index.css",
    "./tw/theme": "./dist/tw/theme.css",
    "./tw/components": "./dist/tw/components/index.css",
    "./tw/surface": "./dist/tw/components/surface.css",
    "./tw/button": "./dist/tw/components/button.css",
    "./tw/form": "./dist/tw/components/form.css",
    "./tw/feedback": "./dist/tw/components/feedback.css",
    "./tw/loader": "./dist/tw/components/loader.css",
    "./tw/tooltip": "./dist/tw/components/tooltip.css",
    "./tw/reset": "./dist/tw/reset.css",
    "./tw/native": "./dist/tw/native.css",
    "./tw/typography": "./dist/tw/typography.css",
    "./tw/utilities": "./dist/tw/utilities/index.css",
    "./native": {
      "style": "./dist/native.css",
      "import": "./dist/native.css",
      "default": "./dist/native.css"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "dev": "pnpm --filter=@codenhub/styles-dev dev",
    "debug": "pnpm build && pnpm --filter=@codenhub/styles-debug dev",
    "build": "pnpm clean && pnpm build:styles && pnpm build:tw",
    "build:styles": "tailwindcss -i ./src/index.css -o ./dist/index.css --minify && tailwindcss -i ./src/theme.css -o ./dist/theme.css --minify && tailwindcss -i ./src/components/index.css -o ./dist/components.css --minify && tailwindcss -i ./src/native.css -o ./dist/native.css --minify",
    "build:tw": "node -e \"require('node:fs').cpSync('src', 'dist/tw', { recursive: true })\"",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "status:npm": "npm view @codenhub/styles version dist-tags time --json && npm dist-tag ls @codenhub/styles && npm access get status @codenhub/styles",
    "status:pack": "npm pack --dry-run",
    "test": "pnpm typecheck && pnpm test:integration && pnpm test:visual:run",
    "test:coverage": "pnpm test",
    "test:integration": "vitest run",
    "test:visual": "pnpm build && pnpm test:visual:run",
    "test:visual:run": "playwright test",
    "test:visual:watch": "playwright test --ui",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tailwindcss/cli": "catalog:",
    "@types/node": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "codenhub": {
    "docs": {
      "label": "Styles",
      "status": "experimental"
    }
  }
}
