{
  "name": "@codenhub/styles",
  "private": false,
  "type": "module",
  "version": "0.0.1",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": "./dist/index.css",
    "./theme": "./dist/theme.css",
    "./components": "./dist/components.css",
    "./tw": "./src/index.css",
    "./tw/theme": "./src/theme.css",
    "./tw/components": "./src/components.css"
  },
  "scripts": {
    "build": "pnpm build:styles",
    "build:styles": "tailwindcss -i ./src/index.css -o ./dist/index.css --minify && tailwindcss -i ./src/theme.css -o ./dist/theme.css --minify && tailwindcss -i ./src/components.css -o ./dist/components.css --minify",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "test": "pnpm typecheck && pnpm test:build && pnpm test:visual",
    "test:build": "pnpm build && pnpm test:build:vanilla && pnpm test:build:tw",
    "test:build:tw": "tailwindcss -i ./tests/build/index.css -o ./tests/build/output.css --minify",
    "test:build:vanilla": "tailwindcss -i ./tests/vanilla/index.css -o ./tests/vanilla/output.css --minify",
    "test:visual": "playwright test",
    "test:watch": "playwright test --ui",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
