{
  "name": "@codenhub/skills",
  "version": "0.0.4",
  "private": false,
  "description": "Curated collection of AI agent skills with a built-in installer.",
  "homepage": "https://github.com/codenhub/codenhub/tree/main/packages/skills",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenhub/codenhub.git",
    "directory": "packages/skills"
  },
  "bin": {
    "codenhub-skills": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "NOTICE",
    "docs/provenance.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts src/cli.ts --format esm --clean --no-fixed-extension --dts",
    "cli": "pnpm build && node dist/cli.js",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "status:npm": "npm view @codenhub/skills version dist-tags time --json && npm dist-tag ls @codenhub/skills && npm access get status @codenhub/skills",
    "status:pack": "npm pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
