{
  "name": "@codenhub/components",
  "version": "0.0.1",
  "private": false,
  "description": "Lightweight, native Web Components wrapper for fast-loading SPA UIs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenhub/codenhub.git",
    "directory": "packages/components"
  },
  "files": [
    "dist",
    "docs/index.md",
    "docs/core-api.md",
    "docs/component-library.md",
    "docs/framework-adapters.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./lib/react": {
      "types": "./dist/lib/react.d.ts",
      "import": "./dist/lib/react.js"
    },
    "./lib/svelte": {
      "types": "./dist/lib/svelte.d.ts",
      "import": "./dist/lib/svelte.js"
    },
    "./lib/astro": {
      "types": "./dist/lib/astro.d.ts",
      "import": "./dist/lib/astro.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts src/lib/index.ts src/lib/react.ts src/lib/svelte.ts src/lib/astro.ts --format esm --dts --clean --no-fixed-extension",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "status:npm": "npm view @codenhub/components version dist-tags time --json && npm dist-tag ls @codenhub/components && npm access get status @codenhub/components",
    "status:pack": "npm pack --dry-run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@codenhub/styles": "workspace:*",
    "astro": ">=4.0.0",
    "react": ">=18.0.0",
    "svelte": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@codenhub/styles": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "astro": {
      "optional": true
    }
  },
  "codenhub": {
    "docs": {
      "label": "Components",
      "status": "experimental"
    }
  }
}
