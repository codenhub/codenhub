{
  "name": "@codenhub/i18n",
  "version": "0.0.1",
  "private": false,
  "description": "Flexible, lightweight i18n translation system with DOM synchronization.",
  "homepage": "https://github.com/codenhub/codenhub/tree/main/packages/i18n",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenhub/codenhub.git",
    "directory": "packages/i18n"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean --no-fixed-extension",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "status:npm": "npm view @codenhub/i18n version dist-tags time --json && npm dist-tag ls @codenhub/i18n && npm access get status @codenhub/i18n",
    "status:pack": "npm pack --dry-run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codenhub/store": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
