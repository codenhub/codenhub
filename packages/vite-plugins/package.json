{
  "name": "@codenhub/vite-plugins",
  "version": "0.0.2",
  "private": false,
  "description": "Vite plugins for icon inlining, CSS deferral, i18n validation, and async loader injection.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codenhub/codenhub.git",
    "directory": "packages/vite-plugins"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean --no-fixed-extension",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "status:npm": "npm view @codenhub/vite-plugins version dist-tags time --json && npm dist-tag ls @codenhub/vite-plugins && npm access get status @codenhub/vite-plugins",
    "status:pack": "npm pack --dry-run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vite": "^8.0.16"
  }
}
