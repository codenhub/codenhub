{
  "name": "@codenhub/ui-kit",
  "version": "0.0.1",
  "private": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scripts": {
      "types": "./dist/scripts/index.d.ts",
      "import": "./dist/scripts/index.js"
    },
    "./styles": "./dist/styles/index.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm build:scripts && pnpm build:styles",
    "build:scripts": "tsdown src/index.ts src/scripts/index.ts --format esm --dts --clean --no-fixed-extension",
    "build:styles": "tailwindcss -i ./src/styles/index.css -o ./dist/styles/index.css --minify",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codenhub/error": "workspace:*",
    "@codenhub/store": "workspace:*",
    "@codenhub/styles": "workspace:*",
    "@codenhub/theme": "workspace:*",
    "@codenhub/validation": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
