{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSpacing": true,
  "htmlWhitespaceSensitivity": "ignore",
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "**/coverage/**",
    "test-results/**",
    "**/test-results/**",
    "**/tests/**/output.css"
  ],
  "printWidth": 120,
  "semi": true,
  "singleQuote": false,
  "sortTailwindcss": true,
  "sortImports": true,
  "sortPackageJson": true,
  "trailingComma": "all"
}
